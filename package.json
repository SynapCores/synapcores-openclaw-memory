{
  "name": "@synapcores/openclaw-memory",
  "version": "0.5.0",
  "description": "OpenClaw long-term memory plugin backed by SynapCores AIDB engine-side MEMORY_STORE/RECALL/FORGET primitives + SQL filtering, graph relations, AutoML relevance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "long-term-memory",
    "synapcores",
    "aidb",
    "vector-search",
    "graph",
    "automl",
    "rag"
  ],
  "author": "SynapCores Team <release@synapcores.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SynapCores/synapcores-openclaw-memory"
  },
  "bugs": {
    "url": "https://github.com/SynapCores/synapcores-openclaw-memory/issues"
  },
  "homepage": "https://synapcores.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@synapcores/sdk": "^0.6.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.10"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@synapcores/openclaw-memory",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10",
      "minSynapCoresEngineVersion": "v1.8.5-ce"
    },
    "build": {
      "openclawVersion": "2026.5.12",
      "pluginSdkVersion": "2026.5.12"
    },
    "compat": {
      "pluginApi": ">=2026.5.19",
      "synapcoresEngine": ">=1.8.5-ce"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
